  }
  .pm-card__q {
    font-family: var(--font-sans); font-size: clamp(1.05rem, 2.2vw, 1.45rem);
    font-weight: 500; line-height: 1.2; letter-spacing: -0.01em; color: #fff;
  }
  .pm-card__pct { text-align: right; flex: none; line-height: 1; }
  .pm-card__pctnum { display: block; font-size: clamp(1.9rem, 5vw, 2.6rem); font-weight: 800; letter-spacing: -0.03em; color: var(--brand-sky); }
  .pm-card__pctnum small { font-size: 0.45em; font-weight: 700; opacity: 0.7; }
  .pm-card__pctlbl { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-faint); }

  .pm-chart { position: relative; height: clamp(84px, 16vw, 130px); }
  .pm-chart svg { width: 100%; height: 100%; display: block; overflow: visible; }

  .pm-buys { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
  .pm-buy {
    display: flex; align-items: center; justify-content: space-between; gap: 0.5rem;
    padding: 0.7rem 0.95rem; border-radius: 0.8rem; border: 1px solid transparent;
