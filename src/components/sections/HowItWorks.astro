  .pm-tab[data-active="true"] .pm-tab__lbl { color: #fff; }

  /* The market card */
  .pm-stage { position: relative; }
  .pm-card {
    display: flex; flex-direction: column; gap: 1.1rem;
    padding: clamp(1.1rem, 2.5vw, 1.6rem);
    border-radius: 1.25rem;
    background:
      radial-gradient(130% 90% at 50% -10%, rgba(126, 59, 255, 0.14), transparent 60%),
      rgba(0, 0, 0, 0.34);
