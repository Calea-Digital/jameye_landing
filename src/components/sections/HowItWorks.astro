  .edge-core {
    position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: clamp(120px, 22vw, 168px); height: clamp(120px, 22vw, 168px); border-radius: 9999px;
    background: radial-gradient(circle at 50% 38%, rgba(16, 185, 129, 0.3), rgba(10, 12, 20, 0.92) 72%);
    border: 1px solid rgba(16, 185, 129, 0.45);
    box-shadow: 0 0 0 8px rgba(16, 185, 129, 0.06), 0 22px 60px -20px rgba(16, 185, 129, 0.75), inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }
  .edge-core--xl { width: clamp(132px, 24vw, 172px); height: clamp(132px, 24vw, 172px); }
  .edge-core__ring { position: absolute; inset: -12px; border-radius: 9999px; border: 1px dashed rgba(16, 185, 129, 0.4); animation: edgeSpin 18s linear infinite; }
  @keyframes edgeSpin { to { transform: rotate(360deg); } }
  .edge-core__bolt { width: clamp(22px, 4vw, 30px); height: clamp(22px, 4vw, 30px); color: var(--win-emerald); filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.8)); margin-bottom: 0.1rem; }
  .edge-core__score { font-family: var(--font-mono); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1; color: var(--win-emerald); }
  .edge-core__label { font-family: var(--font-mono); font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255, 255, 255, 0.7); margin-top: 0.3rem; }
  .hiw-edge__caption { max-width: 40rem; text-align: center; font-size: 0.95rem; line-height: 1.6; color: var(--ink-muted); }

  /* ---- Forecast viz ---- */
  .hiw-fc__q { font-family: var(--font-sans); font-size: clamp(1.05rem, 2vw, 1.25rem); font-weight: 500; color: #fff; line-height: 1.3; margin-bottom: 1.1rem; }
