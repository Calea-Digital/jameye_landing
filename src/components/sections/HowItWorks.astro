  }
  .pm-buy:hover { transform: translateY(-1px); filter: brightness(1.08); }
  .pm-buy__side { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.02em; text-transform: uppercase; }
  .pm-buy__price { font-size: 1rem; font-weight: 800; }
  .pm-buy--yes { background: rgba(41, 98, 255, 0.16); border-color: rgba(91, 141, 255, 0.45); color: #8fb0ff; }
  .pm-buy--no  { background: rgba(216, 59, 255, 0.14); border-color: rgba(216, 59, 255, 0.45); color: #e98bff; }

  .pm-stats { display: flex; align-items: center; justify-content: center; gap: 0.75rem; font-size: 0.8rem; color: var(--ink-muted); }
  .pm-stats__dot { width: 3px; height: 3px; border-radius: 9999px; background: rgba(255, 255, 255, 0.25); }

  /* ============ EDGE SCORE — level-path builder ============ */
  .edge-journey { display: flex; flex-direction: column; }
  .edge-journey__head { text-align: left; max-width: 34rem; margin: 0 0 0.5rem; }
