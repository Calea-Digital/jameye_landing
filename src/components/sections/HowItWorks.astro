  }
  .edge-journey__kdot { width: 7px; height: 7px; border-radius: 9999px; background: var(--brand-magenta); box-shadow: 0 0 10px rgba(216, 59, 255, 0.9); }
  .edge-journey__title { font-family: var(--font-sans); font-size: clamp(1.9rem, 5vw, 3.1rem); font-weight: 700; letter-spacing: -0.035em; line-height: 1.02; }
  .edge-journey__sub { margin: 0.7rem 0 0; max-width: 33rem; font-size: 0.98rem; line-height: 1.55; color: var(--ink-muted); }

  /* Path card surface */
  .edge-map {
    position: relative; width: 100%; margin: 1.5rem 0 0.5rem;
