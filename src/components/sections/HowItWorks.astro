<script>
  type TabEl = HTMLButtonElement;

  document.querySelectorAll<HTMLElement>('[data-hiw]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<TabEl>('[data-hiw-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-hiw-panel]'));
    if (!tabs.length || !panels.length) return;

    const select = (id: string) => {
      tabs.forEach((t) => {
        const active = t.dataset.hiwTab === id;
        t.dataset.active = active ? 'true' : 'false';
        t.setAttribute('aria-expanded', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.dataset.hiwPanel === id;
        p.hidden = !active;
        if (active) { p.style.animation = 'none'; void p.offsetWidth; p.style.animation = ''; }
      });
    };

    tabs.forEach((tab) => tab.addEventListener('click', () => select(tab.dataset.hiwTab!)));
  });

  // Versus auto-cycle inside the Markets panel.
  document.querySelectorAll<HTMLElement>('[data-pickaside]').forEach((root) => {
    const interval = Number(root.dataset.interval ?? 5000);
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-panel]'));
    if (!tabs.length || !panels.length) return;

    let activeIdx = 0;
    let timer: number | undefined;
    let visible = false;

    const setActive = (idx: number) => {
      activeIdx = (idx + tabs.length) % tabs.length;
      tabs.forEach((tab, i) => {
        const active = i === activeIdx;
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
        tab.dataset.active = active ? 'true' : 'false';
      });
      panels.forEach((panel, i) => {
        const active = i === activeIdx;
        panel.setAttribute('aria-hidden', active ? 'false' : 'true');
        panel.classList.toggle('opacity-100', active);
        panel.classList.toggle('relative', active);
        panel.classList.toggle('opacity-0', !active);
        panel.classList.toggle('absolute', !active);
        panel.classList.toggle('inset-0', !active);
        panel.classList.toggle('pointer-events-none', !active);
      });
    };
    const start = () => { stop(); timer = window.setInterval(() => setActive(activeIdx + 1), interval); };
    const stop = () => { if (timer !== undefined) { window.clearInterval(timer); timer = undefined; } };

    tabs.forEach((tab, i) => tab.addEventListener('click', () => { setActive(i); if (visible) start(); }));

    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        visible = entry.isIntersecting;
        if (visible) start(); else stop();
      });
    }, { threshold: 0.25 });
    io.observe(root);
  });
</script>
