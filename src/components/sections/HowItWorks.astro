  .hiw-fc__rail { position: relative; height: 8px; border-radius: 4px; background: rgba(255, 255, 255, 0.08); }
  .hiw-fc__grad { position: absolute; inset: 0; border-radius: 4px; background: linear-gradient(90deg, rgba(244,63,94,0.4), rgba(255,255,255,0.05) 50%, rgba(91,141,255,0.45)); }
