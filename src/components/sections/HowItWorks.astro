---
import { Icon } from 'astro-icon/components';
import { t, type Locale } from '~/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

interface Side {
  name: string;
  image?: string;
  icon?: string;
  odds: number;
}

interface Category {
  id: string;
  label: string;
  question: string;
  sideA: Side;
  sideB: Side;
  volume: string;
  traders: string;
}

interface Concept {
  id: 'markets' | 'forecast' | 'edge' | 'tournaments';
  icon: string;
  label: string;
  tagline: string;
  headline: string;
  body: string;
  points?: string[];
}

const data = t<{
  eyebrow: string;
  title: { lead: string; ital: string };
  sub: string;
  volumeLabel: string;
  tradersLabel: string;
  liveLabel: string;
  vsLabel: string;
  concepts: Concept[];
  edge: { label: string; tag: string; caption: string };
  demo: {
    youLabel: string; youValue: string;
    truthLabel: string; truthValue: string;
    edgeLabel: string; edgeValue: string;
  };
  forecast: { question: string; value: string; confBold: string; confSub: string; anchorNo: string; anchorYes: string; ladder: string[]; activeStep: number };
  tournaments: { prizeAmount: string; prizeHint: string; rows: { rank: string; name: string; edge: string; you?: boolean }[] };
  categories: Category[];
}>(locale, 'how-it-works');

// EDGE is the heart of the section — open on it by default.
const DEFAULT = 'edge';

const INTERVAL_MS = 5000;
const CHART_W = 320;
const CHART_H = 140;
const SERIES_N = 64;
const SIDE_A_COLOR = '#f43f5e';
const SIDE_B_COLOR = '#2962ff';

const LADDER_AVATARS: Record<string, string> = {
  '1': '/avatar/01-open-market-trader.svg',
  '2': '/avatar/12-bonus-dj.svg',
  '12': '/avatar/02-edge-score-explorer.svg',
};

function hashSeed(s: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function mulberry32(seed: number) {
  return () => {
    let t = (seed = (seed + 0x6d2b79f5) >>> 0);
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function buildSeries(catId: string, finalOdds: number, n = SERIES_N): number[] {
  const rng = mulberry32(hashSeed(catId));
  const series: number[] = [];
  let v = 30 + rng() * 40;
  for (let i = 0; i < n; i++) {
    v += (rng() - 0.5) * 12;
    v = Math.max(15, Math.min(85, v));
    const tt = i / (n - 1);
    const driftStart = 0.65;
    const driftAmount = Math.max(0, (tt - driftStart) / (1 - driftStart));
    v = v * (1 - driftAmount * 0.85) + finalOdds * (driftAmount * 0.85);
    series.push(v);
  }
  series[n - 1] = finalOdds;
  return series;
}
function point(v: number, i: number, n: number) {
  return { x: (i / (n - 1)) * CHART_W, y: CHART_H - (v / 100) * CHART_H };
}
function buildLine(series: number[]): string {
  return series.map((v, i) => {
    const { x, y } = point(v, i, series.length);
    return `${x.toFixed(1)},${y.toFixed(1)}`;
  }).join(' ');
}
const charts = data.categories.map((cat) => {
  const seriesA = buildSeries(cat.id, cat.sideA.odds);
  const seriesB = seriesA.map((v) => 100 - v);
  return {
    id: cat.id,
    lineA: buildLine(seriesA),
    lineB: buildLine(seriesB),
    lastA: point(seriesA[seriesA.length - 1], seriesA.length - 1, seriesA.length),
    lastB: point(seriesB[seriesB.length - 1], seriesB.length - 1, seriesB.length),
  };
});
---

<section id="how-it-works" class="py-12 md:py-16">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 w-full">
    <div class="section-head">
      <span class="eyebrow">{data.eyebrow}</span>
      <h2 class="section-title text-white">
        {data.title.lead} <span class="ital-grad">{data.title.ital}</span>
      </h2>
      <p class="section-sub">{data.sub}</p>
    </div>

    <div data-hiw>
      <!-- Concept selector — EDGE Score is the centerpiece. -->
      <div class="hiw-tabs">
        {
          data.concepts.map((c) => (
            <button
              type="button"
              class="hiw-tab"
              data-hiw-tab={c.id}
              data-core={c.id === 'edge' ? 'true' : undefined}
              data-active={c.id === DEFAULT ? 'true' : 'false'}
              aria-expanded={c.id === DEFAULT ? 'true' : 'false'}
              aria-controls={`hiw-panel-${c.id}`}
            >
              <span class="hiw-tab__icon"><Icon name={c.icon} class="w-5 h-5" /></span>
              <span class="hiw-tab__text">
                <span class="hiw-tab__label">{c.label}</span>
                <span class="hiw-tab__tagline">{c.tagline}</span>
              </span>
            </button>
          ))
        }
      </div>

      <!-- Deep-dive panels -->
      <div class="hiw-panels">
        {
          data.concepts.map((c) => (
            <div
              id={`hiw-panel-${c.id}`}
              class="hiw-panel"
              data-hiw-panel={c.id}
              hidden={c.id !== DEFAULT}
            >
              {(c.id === 'markets' || c.id === 'edge') && (
                <div class="hiw-panel__intro">
                  <h3 class="hiw-panel__headline text-white">{c.headline}</h3>
                  <p class="hiw-panel__body">{c.body}</p>
                </div>
              )}

              <!-- MARKETS — the versus visualization. -->
              {c.id === 'markets' && (
                <div class="hiw-markets" data-pickaside data-interval={INTERVAL_MS}>
                  <div class="flex flex-wrap justify-center gap-2" role="tablist">
                    {data.categories.map((cat, i) => (
                      <button
                        type="button"
                        role="tab"
                        data-tab={cat.id}
                        aria-selected={i === 0 ? 'true' : 'false'}
                        data-active={i === 0 ? 'true' : 'false'}
                        class="chip"
                      >
                        {cat.label}
                      </button>
                    ))}
                  </div>

                  <div class="mt-6 relative">
                    {data.categories.map((cat, i) => {
                      const chart = charts.find((ch) => ch.id === cat.id)!;
                      return (
                        <div
                          data-panel={cat.id}
                          role="tabpanel"
                          aria-hidden={i === 0 ? 'false' : 'true'}
                          class:list={['transition-opacity duration-500 ease-out', i === 0 ? 'opacity-100 relative' : 'opacity-0 absolute inset-0 pointer-events-none']}
                        >
                          <p class="text-center text-lg md:text-2xl font-light text-white leading-tight tracking-tight mb-5">{cat.question}</p>
                          <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 md:gap-8">
                            <div class="flex flex-col items-center gap-2">
                              <div class="w-16 h-16 sm:w-24 sm:h-24 md:w-36 md:h-36 flex items-center justify-center">
                                {cat.sideA.image ? (
                                  <img src={cat.sideA.image} alt={cat.sideA.name} class="w-full h-full object-contain drop-shadow-[0_10px_28px_rgba(239,68,68,0.4)]" />
                                ) : cat.sideA.icon ? (
                                  <div class="w-full h-full rounded-full bg-red-500/15 border-2 border-red-500/40 flex items-center justify-center">
                                    <Icon name={cat.sideA.icon} class="w-1/2 h-1/2 text-red-500" />
                                  </div>
                                ) : null}
                              </div>
                              <div class="meta-label" style={`color:${SIDE_A_COLOR}`}>{cat.sideA.name}</div>
                              <div class="num text-2xl sm:text-4xl md:text-5xl font-extrabold leading-none" style={`color:${SIDE_A_COLOR}`}>{cat.sideA.odds}%</div>
                            </div>

                            <div class="flex flex-col items-center w-24 sm:w-36 md:w-56">
                              <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="none" class="w-full h-16 sm:h-24 md:h-28 overflow-visible" aria-hidden="true">
                                <g stroke="currentColor" class="text-border" stroke-width="1" stroke-dasharray="2 6" opacity="0.5">
                                  <line x1="0" y1={CHART_H * 0.5} x2={CHART_W} y2={CHART_H * 0.5} />
                                </g>
                                <polyline points={chart.lineB} fill="none" stroke={SIDE_B_COLOR} stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.95" />
                                <polyline points={chart.lineA} fill="none" stroke={SIDE_A_COLOR} stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.95" />
                                <circle cx={chart.lastB.x} cy={chart.lastB.y} r="4" fill={SIDE_B_COLOR} stroke="var(--card)" stroke-width="2" vector-effect="non-scaling-stroke" />
                                <circle cx={chart.lastA.x} cy={chart.lastA.y} r="4" fill={SIDE_A_COLOR} stroke="var(--card)" stroke-width="2" vector-effect="non-scaling-stroke" />
                              </svg>
                              <div class="mt-2 meta-label">{data.vsLabel}</div>
                            </div>

                            <div class="flex flex-col items-center gap-2">
                              <div class="w-16 h-16 sm:w-24 sm:h-24 md:w-36 md:h-36 flex items-center justify-center">
                                {cat.sideB.image ? (
                                  <img src={cat.sideB.image} alt={cat.sideB.name} class="w-full h-full object-contain drop-shadow-[0_10px_28px_rgba(59,130,246,0.45)]" />
                                ) : cat.sideB.icon ? (
                                  <div class="w-full h-full rounded-full bg-blue-500/15 border-2 border-blue-500/40 flex items-center justify-center">
                                    <Icon name={cat.sideB.icon} class="w-1/2 h-1/2 text-blue-500" />
                                  </div>
                                ) : null}
                              </div>
                              <div class="meta-label" style={`color:${SIDE_B_COLOR}`}>{cat.sideB.name}</div>
                              <div class="num text-2xl sm:text-4xl md:text-5xl font-extrabold leading-none" style={`color:${SIDE_B_COLOR}`}>{cat.sideB.odds}%</div>
                            </div>
                          </div>

                          <div class="mt-5 flex items-center justify-center gap-4 text-xs text-white/55">
                            <span><span class="num text-white">{cat.volume}</span> <span class="meta-label">{data.volumeLabel}</span></span>
                            <span class="w-1 h-1 rounded-full bg-white/20" />
                            <span><span class="num text-white">{cat.traders}</span> <span class="meta-label">{data.tradersLabel}</span></span>
                            <span class="w-1 h-1 rounded-full bg-white/20" />
                            <span class="inline-flex items-center gap-2"><span class="live-dot" /><span class="meta-label">{data.liveLabel}</span></span>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}

              <!-- FORECAST — split: copy + conviction card. -->
              {c.id === 'forecast' && (
                <div class="hiw-split">
                  <div class="hiw-split__intro">
                    <h3 class="hiw-panel__headline text-white">{c.headline}</h3>
                    <p class="hiw-panel__body">{c.body}</p>
                    {c.points && (
                      <ul class="hiw-points">
                        {c.points.map((p) => (
                          <li><Icon name="tabler:check" class="w-3.5 h-3.5" />{p}</li>
                        ))}
                      </ul>
                    )}
                  </div>

                  <div class="hiw-viz">
                    <div class="hiw-fc__q">{data.forecast.question}</div>
                    <div class="hiw-fc__head">
                      <div class="flex items-baseline">
                        <span class="num hiw-fc__pct">{data.forecast.value}</span>
                        <span class="num text-2xl text-white/40">%</span>
                      </div>
                      <div class="text-right">
                        <strong class="block text-white text-sm">{data.forecast.confBold}</strong>
                        <span class="meta-label">{data.forecast.confSub}</span>
                      </div>
                    </div>
                    <div class="hiw-fc__rail">
                      <span class="hiw-fc__grad"></span>
                      <span class="hiw-fc__thumb" style={`left:${data.forecast.value}%`}></span>
                    </div>
                    <div class="hiw-fc__anchors">
                      <span style="color:#ff7e92;">{data.forecast.anchorNo}</span>
                      <span style="color:var(--brand-sky);">{data.forecast.anchorYes}</span>
                    </div>
                    <div class="hiw-fc__ladder">
                      {data.forecast.ladder.map((step, i) => (
                        <span class:list={['hiw-fc__tick', i === data.forecast.activeStep && 'is-active']}>{step}</span>
                      ))}
                    </div>
                  </div>
                </div>
              )}

              <!-- EDGE — the skill score, centerpiece of the section. -->
              {c.id === 'edge' && (
                <div class="hiw-edge">
                  <div class="hiw-edge__flow">
                    <div class="hiw-io">
                      <span class="hiw-io__k">{data.demo.youLabel}</span>
                      <span class="num hiw-io__v" style="color:var(--brand-sky);">{data.demo.youValue}</span>
                    </div>
                    <span class="hiw-io__plus">vs</span>
                    <div class="hiw-io">
                      <span class="hiw-io__k">{data.demo.truthLabel}</span>
                      <span class="num hiw-io__v" style="color:#fff;">{data.demo.truthValue}</span>
                    </div>
                    <Icon name="tabler:arrow-right" class="hiw-io__arrow" />
                    <div class="edge-core edge-core--xl" aria-hidden="true">
                      <span class="edge-core__ring"></span>
                      <Icon name="tabler:bolt" class="edge-core__bolt" />
                      <span class="num edge-core__score">{data.demo.edgeValue}</span>
                      <span class="edge-core__label">{data.edge.label}</span>
                    </div>
                  </div>
                  <p class="hiw-edge__caption">{data.edge.caption}</p>
                </div>
              )}

              <!-- TOURNAMENTS — split: copy + prize & board. -->
              {c.id === 'tournaments' && (
                <div class="hiw-split">
                  <div class="hiw-split__intro">
                    <h3 class="hiw-panel__headline text-white">{c.headline}</h3>
                    <p class="hiw-panel__body">{c.body}</p>
                    {c.points && (
                      <ul class="hiw-points">
                        {c.points.map((p) => (
                          <li><Icon name="tabler:check" class="w-3.5 h-3.5" />{p}</li>
                        ))}
                      </ul>
                    )}
                  </div>

                  <div class="hiw-viz">
                    <div class="hiw-tour__prizebox">
                      <span class="num hiw-tour__amount">{data.tournaments.prizeAmount}</span>
                      <span class="hiw-tour__hint"><Icon name="tabler:trophy" class="w-3.5 h-3.5" />{data.tournaments.prizeHint}</span>
                    </div>
                    <ol class="hiw-board">
                      {data.tournaments.rows.map((r) => (
                        <li class:list={['hiw-row', r.you && 'hiw-row--you']}>
                          <span class="hiw-row__rank num">{r.rank}</span>
                          <img class="hiw-row__avi" src={LADDER_AVATARS[r.rank] ?? LADDER_AVATARS['1']} alt="" loading="lazy" />
                          <span class="hiw-row__name">{r.name}</span>
                          <span class="hiw-row__edge num">{r.edge}<small> EDGE</small></span>
                        </li>
                      ))}
                    </ol>
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Concept selector ---- */
  .hiw-tabs {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .hiw-tab {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-align: left;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    background: var(--glass-card-bg);
    border: 1px solid var(--hairline);
    transition: transform 250ms ease, border-color 250ms ease, background 250ms ease;
  }
  .hiw-tab:hover { transform: translateY(-3px); border-color: var(--hairline-strong); }
  .hiw-tab__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.5rem; height: 2.5rem; flex-shrink: 0; border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.05); border: 1px solid var(--hairline);
    color: rgba(255, 255, 255, 0.7); transition: all 250ms ease;
  }
  .hiw-tab__text { display: flex; flex-direction: column; min-width: 0; }
  .hiw-tab__label { font-family: var(--font-sans); font-size: 1rem; font-weight: 500; color: #fff; letter-spacing: -0.01em; }
  .hiw-tab__tagline { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin-top: 0.1rem; }

  .hiw-tab[data-active="true"] {
    border-color: var(--hairline-strong);
    background: rgba(255, 255, 255, 0.06);
  }
  .hiw-tab[data-active="true"] .hiw-tab__icon {
    background-image: var(--gradient-brand-sweep);
    border-color: transparent; color: #fff;
    box-shadow: var(--shadow-brand-halo);
  }
  /* EDGE Score reads as the heart of the section. */
  .hiw-tab[data-core] .hiw-tab__icon { color: var(--win-emerald); }
  .hiw-tab[data-core][data-active="true"] {
    border-color: rgba(16, 185, 129, 0.4);
    box-shadow: 0 0 32px -14px rgba(16, 185, 129, 0.7);
  }
  .hiw-tab[data-core][data-active="true"] .hiw-tab__icon {
    background-image: var(--gradient-emerald-teal);
    color: #06281f;
    box-shadow: 0 0 22px -6px rgba(16, 185, 129, 0.8);
  }

  /* ---- Panels ---- */
  .hiw-panel {
    padding: clamp(1.5rem, 3.5vw, 2.5rem);
    border-radius: var(--radius-2xl);
    background: var(--glass-card-bg);
    border: 1px solid var(--hairline);
    box-shadow: var(--shadow-soft-chrome);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    animation: hiwIn 420ms cubic-bezier(0.2, 0.85, 0.2, 1);
  }
  .hiw-panel[hidden] { display: none; }
  @keyframes hiwIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  .hiw-panel__intro { text-align: center; max-width: 40rem; margin: 0 auto 1.75rem; }
  .hiw-panel__headline { font-family: var(--font-sans); font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 400; letter-spacing: -0.025em; line-height: 1.08; margin-bottom: 0.75rem; }
  .hiw-panel__body { font-size: 1rem; line-height: 1.6; color: var(--ink-muted); }

  /* ---- Split layout (forecast + tournaments) ---- */
  .hiw-split {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: clamp(1.5rem, 3.5vw, 2.75rem);
    align-items: center;
  }
  .hiw-split__intro { text-align: left; }
  .hiw-split__intro .hiw-panel__headline { margin-bottom: 0.75rem; }
  .hiw-points { list-style: none; margin-top: 1.25rem; display: flex; flex-direction: column; gap: 0.65rem; }
  .hiw-points li { display: flex; align-items: center; gap: 0.6rem; font-size: 0.92rem; color: rgba(255, 255, 255, 0.8); }
  .hiw-points li svg { flex: none; color: var(--win-emerald); }

  /* Inset visualization card — gives the panels page-consistent depth. */
  .hiw-viz {
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--hairline);
    border-radius: 1.25rem;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  @media (max-width: 760px) { .hiw-split { grid-template-columns: 1fr; } }

  /* ---- EDGE viz (centerpiece) ---- */
  .hiw-edge { display: flex; flex-direction: column; align-items: center; gap: 1.75rem; }
  .hiw-edge__flow { display: flex; align-items: center; justify-content: center; gap: clamp(0.6rem, 2vw, 1.4rem); flex-wrap: wrap; }
  .hiw-io {
    display: flex; flex-direction: column; align-items: center; gap: 0.35rem; min-width: 6rem; padding: 0.9rem 1.2rem;
    background: rgba(255, 255, 255, 0.035); border: 1px solid var(--hairline); border-radius: 1rem;
  }
  .hiw-io__k { font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-faint); }
  .hiw-io__v { font-size: clamp(1.5rem, 4vw, 2.1rem); font-weight: 700; letter-spacing: -0.03em; line-height: 1; }
  .hiw-io__plus { font-family: var(--font-mono); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink-faint); }
  .hiw-io__arrow { width: 24px; height: 24px; color: var(--ink-faint); flex: none; }

  .edge-core {
    position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center;
    width: clamp(120px, 22vw, 168px); height: clamp(120px, 22vw, 168px); border-radius: 9999px;
    background: radial-gradient(circle at 50% 38%, rgba(16, 185, 129, 0.3), rgba(10, 12, 20, 0.92) 72%);
    border: 1px solid rgba(16, 185, 129, 0.45);
    box-shadow: 0 0 0 8px rgba(16, 185, 129, 0.06), 0 22px 60px -20px rgba(16, 185, 129, 0.75), inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }
  .edge-core--xl { width: clamp(132px, 24vw, 172px); height: clamp(132px, 24vw, 172px); }
  .edge-core__ring { position: absolute; inset: -12px; border-radius: 9999px; border: 1px dashed rgba(16, 185, 129, 0.4); animation: edgeSpin 18s linear infinite; }
  @keyframes edgeSpin { to { transform: rotate(360deg); } }
  .edge-core__bolt { width: clamp(22px, 4vw, 30px); height: clamp(22px, 4vw, 30px); color: var(--win-emerald); filter: drop-shadow(0 0 10px rgba(16, 185, 129, 0.8)); margin-bottom: 0.1rem; }
  .edge-core__score { font-family: var(--font-mono); font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1; color: var(--win-emerald); }
  .edge-core__label { font-family: var(--font-mono); font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255, 255, 255, 0.7); margin-top: 0.3rem; }
  .hiw-edge__caption { max-width: 40rem; text-align: center; font-size: 0.95rem; line-height: 1.6; color: var(--ink-muted); }

  /* ---- Forecast viz ---- */
  .hiw-fc__q { font-family: var(--font-sans); font-size: clamp(1.05rem, 2vw, 1.25rem); font-weight: 500; color: #fff; line-height: 1.3; margin-bottom: 1.1rem; }
