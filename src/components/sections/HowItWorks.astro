    flex: 1; text-align: center; font-family: var(--font-mono); font-size: 0.54rem; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--ink-faint); padding: 0.4rem 0.2rem; border-radius: 0.5rem; border: 1px solid transparent;
  }
  .hiw-fc__tick.is-active { color: #fff; background: rgba(126, 59, 255, 0.18); border-color: rgba(126, 59, 255, 0.4); }

  /* ---- Tournaments viz ---- */
