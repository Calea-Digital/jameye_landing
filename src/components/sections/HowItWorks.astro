    position: absolute; top: 50%; width: 28px; height: 28px; margin: -14px 0 0 -14px; border-radius: 9999px;
    background: #fff; border: 3px solid var(--brand-purple); box-shadow: 0 6px 20px rgba(126,59,255,0.7);
