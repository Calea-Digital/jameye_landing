---
import { Icon } from 'astro-icon/components';
import { t, type Locale } from '~/utils/i18n';
import { getLiveMarkets, type LiveMarket } from '~/utils/polymarket';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

interface Side {
  name: string;
  image?: string;
  icon?: string;
  odds: number;
}

interface Category {
  id: string;
  label: string;
  question: string;
  sideA: Side;
  sideB: Side;
  volume: string;
  traders: string;
}

interface Concept {
  id: 'markets' | 'forecast' | 'edge' | 'tournaments';
  icon: string;
  label: string;
  tagline: string;
  headline: string;
  body: string;
  points?: string[];
}

const data = t<{
  eyebrow: string;
  title: { lead: string; ital: string };
  sub: string;
  volumeLabel: string;
  tradersLabel: string;
  liveLabel: string;
  vsLabel: string;
  concepts: Concept[];
  edge: { label: string; tag: string; caption: string };
  demo: {
    youLabel: string; youValue: string;
    truthLabel: string; truthValue: string;
    edgeLabel: string; edgeValue: string;
  };
  forecast: { question: string; value: string; confBold: string; confSub: string; anchorNo: string; anchorYes: string; ladder: string[]; activeStep: number };
  tournaments: { prizeAmount: string; prizeHint: string; rows: { rank: string; name: string; edge: string; you?: boolean }[] };
  categories: Category[];
  liquidityLabel: string;
  yesLabel: string;
  noLabel: string;
  edgeJourney: {
    kicker: string;
    title: { lead: string; ital: string };
    sub: string;
    startLabel: string;
    vaultBanner: string;
    bossCaption: string;
    nodes: { state: 'locked' | 'active' | 'complete'; star: number }[];
  };
}>(locale, 'how-it-works');

// EDGE is the heart of the section — open on it by default.
const DEFAULT = 'edge';

const INTERVAL_MS = 5000;
const CHART_W = 320;
const CHART_H = 120;
const SERIES_N = 64;

const LADDER_AVATARS: Record<string, string> = {
  '1': '/avatar/01-open-market-trader.svg',
  '2': '/avatar/12-bonus-dj.svg',
  '12': '/avatar/02-edge-score-explorer.svg',
};

// ---- Markets feed: live Polymarket data, curated markets as the fallback. ----
interface MarketCard {
  id: string;
  label: string;
  question: string;
  image: string;
  yes: number;
  no: number;
  volume: string;
  liquidity: string;
}

let live: LiveMarket[] = [];
try { live = await getLiveMarkets(6); } catch { live = []; }

const fallbackMarkets: MarketCard[] = data.categories.map((cat) => ({
  id: cat.id,
  label: cat.label,
  question: cat.question,
  image: cat.sideA.image ?? cat.sideB.image ?? '',
  yes: cat.sideA.odds,
  no: cat.sideB.odds,
  volume: cat.volume,
  liquidity: cat.traders,
}));

const markets: MarketCard[] = live.length >= 3 ? live : fallbackMarkets;
const marketsAreLive = live.length >= 3;

// Our own category icons + brand gradients, so the card stays on-brand even
// though the data is Polymarket's. Matches both live and curated labels (en/es).
function iconFor(label: string): string {
  const s = label.toLowerCase();
  if (s.includes('crypto') || s.includes('cripto')) return 'tabler:currency-bitcoin';
  if (s.includes('polit')) return 'tabler:gavel';
  if (s.includes('sport') || s.includes('deport')) return 'tabler:ball-football';
  if (s.includes('econ')) return 'tabler:chart-line';
  if (s.includes('cultur')) return 'tabler:microphone-2';
  if (s.includes('clima')) return 'tabler:temperature';
  if (s.includes('future') || s.includes('futuro')) return 'tabler:rocket';
  return 'tabler:flame';
}
const TILE_TONES = ['indigo-violet', 'violet-magenta', 'magenta-pink', 'emerald-blue', 'brand-sweep', 'gold-orange'];

function hashSeed(s: string): number {
  let h = 2166136261 >>> 0;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  return h >>> 0;
}
function mulberry32(seed: number) {
  return () => {
    let t = (seed = (seed + 0x6d2b79f5) >>> 0);
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
function buildSeries(catId: string, finalOdds: number, n = SERIES_N): number[] {
  const rng = mulberry32(hashSeed(catId));
  const series: number[] = [];
  let v = 30 + rng() * 40;
  for (let i = 0; i < n; i++) {
    v += (rng() - 0.5) * 12;
    v = Math.max(15, Math.min(85, v));
    const tt = i / (n - 1);
    const driftStart = 0.65;
    const driftAmount = Math.max(0, (tt - driftStart) / (1 - driftStart));
    v = v * (1 - driftAmount * 0.85) + finalOdds * (driftAmount * 0.85);
    series.push(v);
  }
  series[n - 1] = finalOdds;
  return series;
}
function point(v: number, i: number, n: number) {
  return { x: (i / (n - 1)) * CHART_W, y: CHART_H - (v / 100) * CHART_H };
}
// One Yes-probability line per market + a gradient area fill underneath it,
// Polymarket-style. The series is seeded from the market id so it's stable
// across renders and lands on the real current odds.
const charts = markets.map((mk) => {
  const series = buildSeries(mk.id, mk.yes);
  const pts = series.map((v, i) => point(v, i, series.length));
  const line = pts.map((p) => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ');
  const area = `M ${pts.map((p) => `${p.x.toFixed(1)} ${p.y.toFixed(1)}`).join(' L ')} L ${CHART_W} ${CHART_H} L 0 ${CHART_H} Z`;
  return { id: mk.id, line, area, last: pts[pts.length - 1] };
});

// ---- Edge Score journey: a winding level-path through the brand canvas. ----
const JOURNEY_W = 1000;
const JOURNEY_H = 300;
// Track control points (viewBox units): START avatar, 5 lock nodes, then the
// BOSS/vault terminal. The path runs through all of them as one S-curve.
const journeyPts = [
  { x: 72,  y: 215 }, // 0 — start avatar
  { x: 220, y: 200 }, // 1 — lock
  { x: 360, y: 108 }, // 2 — lock
  { x: 515, y: 205 }, // 3 — lock
  { x: 668, y: 100 }, // 4 — active lock
  { x: 788, y: 205 }, // 5 — lock
  { x: 858, y: 150 }, // 6 — boss / vault (kept inset so it never clips)
];
// Catmull-Rom → cubic bezier so the glowing path passes through every node.
function smoothPath(pts: { x: number; y: number }[]): string {
  if (pts.length < 2) return '';
  let d = `M ${pts[0].x} ${pts[0].y}`;
  for (let i = 0; i < pts.length - 1; i++) {
    const p0 = pts[i - 1] ?? pts[i];
    const p1 = pts[i];
    const p2 = pts[i + 1];
    const p3 = pts[i + 2] ?? p2;
    const c1x = p1.x + (p2.x - p0.x) / 6;
    const c1y = p1.y + (p2.y - p0.y) / 6;
    const c2x = p2.x - (p3.x - p1.x) / 6;
    const c2y = p2.y - (p3.y - p1.y) / 6;
    d += ` C ${c1x.toFixed(1)} ${c1y.toFixed(1)}, ${c2x.toFixed(1)} ${c2y.toFixed(1)}, ${p2.x} ${p2.y}`;
  }
  return d;
}
const pct = (p: { x: number; y: number }) => ({ left: (p.x / JOURNEY_W) * 100, top: (p.y / JOURNEY_H) * 100 });
const journeyPath = smoothPath(journeyPts);
// The lit "progress" segment runs from start through the active (4th) lock.
const progressPath = smoothPath(journeyPts.slice(0, 5));
// Lock nodes sit on points 1..5; start avatar on 0, the vault on 6.
const journeyNodes = (data.edgeJourney?.nodes ?? []).map((n, i) => ({ ...n, ...pct(journeyPts[i + 1]) }));
const startPos = pct(journeyPts[0]);
const bossPos = pct(journeyPts[journeyPts.length - 1]);
---

<section id="how-it-works" class="py-12 md:py-16">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 w-full">
    <div class="section-head">
      <span class="eyebrow">{data.eyebrow}</span>
      <h2 class="section-title text-white">
        {data.title.lead} <span class="ital-grad">{data.title.ital}</span>
      </h2>
      <p class="section-sub">{data.sub}</p>
    </div>

    <div data-hiw>
      <!-- Concept selector — EDGE Score is the centerpiece. -->
      <div class="hiw-tabs">
        {
          data.concepts.map((c) => (
            <button
              type="button"
              class="hiw-tab"
              data-hiw-tab={c.id}
              data-core={c.id === 'edge' ? 'true' : undefined}
              data-active={c.id === DEFAULT ? 'true' : 'false'}
              aria-expanded={c.id === DEFAULT ? 'true' : 'false'}
              aria-controls={`hiw-panel-${c.id}`}
            >
              <span class="hiw-tab__icon"><Icon name={c.icon} class="w-5 h-5" /></span>
              <span class="hiw-tab__text">
                <span class="hiw-tab__label">{c.label}</span>
                <span class="hiw-tab__tagline">{c.tagline}</span>
              </span>
            </button>
          ))
        }
      </div>

      <!-- Deep-dive panels -->
      <div class="hiw-panels">
        {
          data.concepts.map((c) => (
            <div
              id={`hiw-panel-${c.id}`}
              class="hiw-panel"
              data-hiw-panel={c.id}
              hidden={c.id !== DEFAULT}
            >
              {c.id === 'markets' && (
                <div class="hiw-panel__intro">
                  <h3 class="hiw-panel__headline text-white">{c.headline}</h3>
                  <p class="hiw-panel__body">{c.body}</p>
                </div>
              )}

              <!-- MARKETS — a live Polymarket-style market card. -->
              {c.id === 'markets' && (
                <div class="pm" data-pickaside data-interval={INTERVAL_MS}>
                  <!-- Market switcher — thumbnail pills, auto-cycling. -->
                  <div class="pm-switch" role="tablist">
                    {markets.map((mk, i) => (
                      <button
                        type="button"
                        role="tab"
                        data-tab={mk.id}
                        aria-selected={i === 0 ? 'true' : 'false'}
                        data-active={i === 0 ? 'true' : 'false'}
                        class="pm-tab"
                      >
                        <span class="pm-tab__icon" style={`background-image:var(--gradient-${TILE_TONES[i % TILE_TONES.length]})`}>
                          <Icon name={iconFor(mk.label)} class="w-3.5 h-3.5" />
                        </span>
                        <span class="pm-tab__lbl">{mk.label}</span>
                        <span class="num pm-tab__pct">{mk.yes}%</span>
                      </button>
                    ))}
                  </div>

                  <div class="pm-stage">
                    {markets.map((mk, i) => {
                      const chart = charts.find((ch) => ch.id === mk.id)!;
                      const gid = `pmfill-${mk.id}`;
                      return (
                        <article
                          data-panel={mk.id}
                          role="tabpanel"
                          aria-hidden={i === 0 ? 'false' : 'true'}
                          class:list={['pm-card transition-opacity duration-500 ease-out', i === 0 ? 'opacity-100 relative' : 'opacity-0 absolute inset-0 pointer-events-none']}
                        >
                          <header class="pm-card__head">
                            <span class="pm-card__thumb" style={`background-image:var(--gradient-${TILE_TONES[i % TILE_TONES.length]})`}>
                              <Icon name={iconFor(mk.label)} class="w-6 h-6" />
                            </span>
                            <div class="pm-card__headtext">
                              <span class="pm-live"><span class="live-dot" />{data.liveLabel}{marketsAreLive ? ' · Polymarket' : ''}</span>
                              <h4 class="pm-card__q">{mk.question}</h4>
                            </div>
                            <div class="pm-card__pct">
                              <span class="num pm-card__pctnum">{mk.yes}<small>%</small></span>
                              <span class="pm-card__pctlbl">{data.yesLabel}</span>
                            </div>
                          </header>

                          <div class="pm-chart">
                            <svg viewBox={`0 0 ${CHART_W} ${CHART_H}`} preserveAspectRatio="none" aria-hidden="true">
                              <defs>
                                <linearGradient id={gid} x1="0" y1="0" x2="0" y2="1">
                                  <stop offset="0%" stop-color="rgba(126,59,255,0.42)" />
                                  <stop offset="100%" stop-color="rgba(126,59,255,0)" />
                                </linearGradient>
                                <linearGradient id={`${gid}-line`} x1="0" y1="0" x2="1" y2="0">
                                  <stop offset="0%" stop-color="#5b8dff" />
                                  <stop offset="55%" stop-color="#7e3bff" />
                                  <stop offset="100%" stop-color="#d83bff" />
                                </linearGradient>
                              </defs>
                              <path d={chart.area} fill={`url(#${gid})`} />
                              <polyline points={chart.line} fill="none" stroke={`url(#${gid}-line)`} stroke-width="2.4" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" />
                              <circle cx={chart.last.x} cy={chart.last.y} r="3.5" fill="#d83bff" stroke="#0a0c14" stroke-width="2" vector-effect="non-scaling-stroke" />
                            </svg>
                          </div>

                          <div class="pm-buys">
                            <button type="button" class="pm-buy pm-buy--yes">
                              <span class="pm-buy__side">{data.yesLabel}</span>
                              <span class="num pm-buy__price">{mk.yes}¢</span>
                            </button>
                            <button type="button" class="pm-buy pm-buy--no">
                              <span class="pm-buy__side">{data.noLabel}</span>
                              <span class="num pm-buy__price">{mk.no}¢</span>
                            </button>
                          </div>

                          <div class="pm-stats">
                            <span><span class="num text-white">{mk.volume}</span> <span class="meta-label">{data.volumeLabel}</span></span>
                            <span class="pm-stats__dot" />
                            <span><span class="num text-white">{mk.liquidity}</span> <span class="meta-label">{data.liquidityLabel}</span></span>
                          </div>
                        </article>
                      );
                    })}
                  </div>
                </div>
              )}

              <!-- EDGE — a level-path journey to a Certified Edge Score. -->
              {c.id === 'edge' && (
                <div class="edge-journey">
                  <div class="edge-journey__head">
                    <span class="edge-journey__kicker"><span class="edge-journey__kdot" />{data.edgeJourney.kicker}</span>
                    <h3 class="edge-journey__title text-white">
                      {data.edgeJourney.title.lead} <span class="ital-grad">{data.edgeJourney.title.ital}</span>
                    </h3>
                    <p class="edge-journey__sub">{data.edgeJourney.sub}</p>
                  </div>

                  <div class="edge-map">
                    <svg class="edge-map__path" viewBox={`0 0 ${JOURNEY_W} ${JOURNEY_H}`} preserveAspectRatio="none" aria-hidden="true">
                      <defs>
                        <linearGradient id="edgePathGrad" x1="0" y1="0" x2="1" y2="0">
                          <stop offset="0%" stop-color="#7e3bff" />
                          <stop offset="100%" stop-color="#d83bff" />
                        </linearGradient>
                        <linearGradient id="edgeProgGrad" x1="0" y1="0" x2="1" y2="0">
                          <stop offset="0%" stop-color="#7e3bff" />
                          <stop offset="100%" stop-color="#d83bff" />
                        </linearGradient>
                        <linearGradient id="edgeFlowGrad" x1="0" y1="0" x2="1" y2="0">
                          <stop offset="0%" stop-color="#a78bff" />
                          <stop offset="55%" stop-color="#e879f9" />
                          <stop offset="100%" stop-color="#f5d0fe" />
                        </linearGradient>
                        <filter id="edgeGlow" x="-20%" y="-80%" width="140%" height="260%">
                          <feGaussianBlur stdDeviation="5" result="b" />
                          <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
                        </filter>
                      </defs>
                      <!-- Track: neon edge glow, dark band, dashed centre line. -->
                      <path d={journeyPath} fill="none" stroke="url(#edgePathGrad)" stroke-width="34" stroke-linecap="round" opacity="0.32" filter="url(#edgeGlow)" />
                      <path d={journeyPath} fill="none" stroke="#170d2b" stroke-width="24" stroke-linecap="round" />
                      <path d={journeyPath} fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="2" stroke-dasharray="2 12" stroke-linecap="round" />
                      <!-- Progress segment (start → active) reads brighter. -->
                      <path d={progressPath} fill="none" stroke="url(#edgeProgGrad)" stroke-width="26" stroke-linecap="round" opacity="0.5" filter="url(#edgeGlow)" />
                      <!-- Purple energy pulsing through the whole pipe. -->
                      <path class="edge-map__flow" d={journeyPath} fill="none" stroke="url(#edgeFlowGrad)" stroke-width="7" stroke-linecap="round" stroke-dasharray="20 30" filter="url(#edgeGlow)" />
                      <circle class="edge-map__packet" r="6" fill="#f0abfc" filter="url(#edgeGlow)">
                        <animateMotion dur="2.6s" repeatCount="indefinite" path={journeyPath} />
                      </circle>
                      <circle class="edge-map__packet" r="5" fill="#c79cff" filter="url(#edgeGlow)">
                        <animateMotion dur="2.6s" begin="1.3s" repeatCount="indefinite" path={journeyPath} />
                      </circle>
                    </svg>

                    <!-- Start: small explorer + label. -->
                    <div class="edge-start" style={`left:${startPos.left}%; top:${startPos.top}%;`}>
                      <img class="edge-start__avi" src="/avatar/02-edge-score-explorer.svg" alt="" loading="lazy" />
                      <span class="edge-start__label">{data.edgeJourney.startLabel}</span>
                    </div>

                    <!-- Five lock gates along the curve. -->
                    {journeyNodes.map((n, i) => (
                      <div
                        class:list={['edge-lock', `edge-lock--${n.state}`]}
                        style={`left:${n.left}%; top:${n.top}%; --d:${i * 0.1}s;`}
                      >
                        <span class="edge-lock__badge num">★{n.star}</span>
                        <span class="edge-lock__tile"><Icon name="tabler:lock" class="w-5 h-5" /></span>
                      </div>
                    ))}

                    <!-- Boss avatar guarding the certified vault. -->
                    <div class="edge-vault" style={`left:${bossPos.left}%; top:${bossPos.top}%;`}>
                      <div class="edge-vault__door">
                        <span class="edge-vault__banner">{data.edgeJourney.vaultBanner}</span>
                        <div class="edge-vault__rewards">
                          <Icon name="tabler:cash-banknote" class="edge-vault__rw edge-vault__rw--cash" />
                          <Icon name="tabler:trophy" class="edge-vault__rw edge-vault__rw--trophy" />
                          <Icon name="tabler:cash-banknote" class="edge-vault__rw edge-vault__rw--cash" />
                        </div>
                        <span class="edge-vault__seal"><Icon name="tabler:lock" class="w-3.5 h-3.5" /></span>
                      </div>
                      <img class="edge-vault__boss" src="/avatar/09-squad-row2-rival.svg" alt="" loading="lazy" />
                    </div>
                  </div>

                  <p class="edge-journey__caption"><Icon name="tabler:rosette-discount-check" class="w-4 h-4" />{data.edgeJourney.bossCaption}</p>
                </div>
              )}

              <!-- TOURNAMENTS — split: copy + prize & board. -->
              {c.id === 'tournaments' && (
                <div class="hiw-split">
                  <div class="hiw-split__intro">
                    <h3 class="hiw-panel__headline text-white">{c.headline}</h3>
                    <p class="hiw-panel__body">{c.body}</p>
                    {c.points && (
                      <ul class="hiw-points">
                        {c.points.map((p) => (
                          <li><Icon name="tabler:check" class="w-3.5 h-3.5" />{p}</li>
                        ))}
                      </ul>
                    )}
                  </div>

                  <div class="hiw-viz">
                    <div class="hiw-tour__prizebox">
                      <span class="num hiw-tour__amount">{data.tournaments.prizeAmount}</span>
                      <span class="hiw-tour__hint"><Icon name="tabler:trophy" class="w-3.5 h-3.5" />{data.tournaments.prizeHint}</span>
                    </div>
                    <ol class="hiw-board">
                      {data.tournaments.rows.map((r) => (
                        <li class:list={['hiw-row', r.you && 'hiw-row--you']}>
                          <span class="hiw-row__rank num">{r.rank}</span>
                          <img class="hiw-row__avi" src={LADDER_AVATARS[r.rank] ?? LADDER_AVATARS['1']} alt="" loading="lazy" />
                          <span class="hiw-row__name">{r.name}</span>
                          <span class="hiw-row__edge num">{r.edge}<small> EDGE</small></span>
                        </li>
                      ))}
                    </ol>
                  </div>
                </div>
              )}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* ---- Concept selector ---- */
  .hiw-tabs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }
  .hiw-tab {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-align: left;
    padding: 0.9rem 1rem;
    border-radius: 1rem;
    background: var(--glass-card-bg);
    border: 1px solid var(--hairline);
    transition: transform 250ms ease, border-color 250ms ease, background 250ms ease;
  }
  .hiw-tab:hover { transform: translateY(-3px); border-color: var(--hairline-strong); }
  .hiw-tab__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.5rem; height: 2.5rem; flex-shrink: 0; border-radius: 0.7rem;
    background: rgba(255, 255, 255, 0.05); border: 1px solid var(--hairline);
    color: rgba(255, 255, 255, 0.7); transition: all 250ms ease;
  }
  .hiw-tab__text { display: flex; flex-direction: column; min-width: 0; }
  .hiw-tab__label { font-family: var(--font-sans); font-size: 1rem; font-weight: 500; color: #fff; letter-spacing: -0.01em; }
  .hiw-tab__tagline { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faint); margin-top: 0.1rem; }

  .hiw-tab[data-active="true"] {
    border-color: var(--hairline-strong);
    background: rgba(255, 255, 255, 0.06);
  }
  .hiw-tab[data-active="true"] .hiw-tab__icon {
    background-image: var(--gradient-brand-sweep);
    border-color: transparent; color: #fff;
    box-shadow: var(--shadow-brand-halo);
  }
  /* EDGE Score reads as the heart of the section. */
  .hiw-tab[data-core] .hiw-tab__icon { color: var(--win-emerald); }
  .hiw-tab[data-core][data-active="true"] {
    border-color: rgba(16, 185, 129, 0.4);
    box-shadow: 0 0 32px -14px rgba(16, 185, 129, 0.7);
  }
  .hiw-tab[data-core][data-active="true"] .hiw-tab__icon {
    background-image: var(--gradient-emerald-teal);
    color: #06281f;
    box-shadow: 0 0 22px -6px rgba(16, 185, 129, 0.8);
  }

  /* ---- Panels ---- */
  .hiw-panel {
    padding: clamp(1.5rem, 3.5vw, 2.5rem);
    border-radius: var(--radius-2xl);
