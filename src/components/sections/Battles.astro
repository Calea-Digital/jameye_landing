<script>
  document.querySelectorAll<HTMLElement>('[data-battles]').forEach((root) => {
    const tabs = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-battle-tab]'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-battle-panel]'));
    const hint = root.querySelector<HTMLElement>('[data-battle-hint]');
    if (!tabs.length || !panels.length) return;

    let touched = false;

    const select = (id: string) => {
      tabs.forEach((t) => {
        const active = t.dataset.battleTab === id;
        t.dataset.active = active ? 'true' : 'false';
        t.setAttribute('aria-expanded', active ? 'true' : 'false');
      });
      panels.forEach((p) => {
        const active = p.dataset.battlePanel === id;
        p.hidden = !active;
        if (active) {
          p.style.animation = 'none';
          void p.offsetWidth;
          p.style.animation = '';
        }
      });
      if (hint && !touched) {
        touched = true;
        hint.style.opacity = '0';
      }
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => select(tab.dataset.battleTab!));
    });
  });

  // Single-select groups inside the Squad Game lobby (modes + segmented controls).
  document.querySelectorAll<HTMLElement>('[data-single]').forEach((group) => {
    const btns = Array.from(group.querySelectorAll<HTMLButtonElement>('button'));
    btns.forEach((btn) => btn.addEventListener('click', () => {
      btns.forEach((b) => (b.dataset.active = b === btn ? 'true' : 'false'));
    }));
  });

  // Preview countdown ticker — decrements D:H:M:S once per second.
  document.querySelectorAll<HTMLElement>('[data-countdown]').forEach((root) => {
    const cells = Array.from(root.querySelectorAll<HTMLElement>('[data-unit]'));
    if (cells.length !== 4) return;
    let t = cells.map((c) => parseInt(c.textContent || '0', 10));
    const pad = (n: number) => String(n).padStart(2, '0');
    const render = () => cells.forEach((c, i) => (c.textContent = pad(t[i])));
    window.setInterval(() => {
      let [d, h, m, sec] = t;
      sec--;
      if (sec < 0) { sec = 59; m--; }
      if (m < 0) { m = 59; h--; }
      if (h < 0) { h = 23; d--; }
      if (d < 0) { d = 0; h = 0; m = 0; sec = 0; }
      t = [d, h, m, sec];
      render();
    }, 1000);
  });
</script>
