---
import { Icon } from 'astro-icon/components';
import { t, type Locale } from '~/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const data = t<{
  title: { lead: string; ital: string };
  body: string;
  ghostWord: string;
  cta: { primary: string; secondary: string };
}>(locale, 'cta-final');
---

<section class="relative py-16 md:py-20 text-center overflow-hidden">
  <!-- Huge ghost background word. -->
  <span
    aria-hidden="true"
    class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none select-none z-0"
    style="font-size: clamp(18rem, 38vw, 37.5rem); line-height: 1; color: rgba(255,255,255,0.025); letter-spacing: -0.04em;"
  >
    {data.ghostWord}
  </span>

  <div class="relative z-10 max-w-[1280px] mx-auto px-5 md:px-8 w-full">
    <div class="max-w-[880px] mx-auto">
      <h2 class="display-hero text-white" style="font-size: clamp(3.5rem, 8vw, 7.5rem);">
        {data.title.lead} <span class="ital-grad">{data.title.ital}</span>
      </h2>
      <p class="mt-7 text-lg md:text-xl text-white/65 leading-relaxed max-w-[560px] mx-auto">
        {data.body}
      </p>

      <div class="mt-12 flex justify-center gap-4 flex-wrap">
        <button type="button" class="cta-big" data-open-waitlist>
          {data.cta.primary}
          <Icon name="tabler:arrow-right" class="w-3.5 h-3.5" />
        </button>
        <a href="#how-it-works" class="cta-ghost">{data.cta.secondary}</a>
      </div>
    </div>
  </div>
</section>
