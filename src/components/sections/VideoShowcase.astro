---
import { t, type Locale } from '~/utils/i18n';

export interface Props {
  locale: Locale;
  src?: string;
  poster?: string;
}

const { locale, src = '/videos/jameye-explainer_fey.mp4', poster } = Astro.props;

const data = t<{ eyebrow: string; title: { lead: string; ital: string }; sub: string }>(locale, 'video');
---

<section id="video" class="py-12 md:py-16">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 w-full">
    <div class="section-head">
      <span class="eyebrow">{data.eyebrow}</span>
      <h2 class="section-title text-white">
        {data.title.lead} <span class="ital-grad">{data.title.ital}</span>
      </h2>
      <p class="section-sub">{data.sub}</p>
    </div>

    <div class="glass-card p-2 md:p-3 overflow-hidden">
      <div class="relative w-full rounded-xl md:rounded-2xl overflow-hidden bg-black aspect-video">
        <video
          data-autoplay-video
          controls
          controlsList="nodownload"
          playsinline
          preload="metadata"
          poster={poster}
          class="w-full h-full object-cover"
        >
          <source src={src} type="video/mp4" />
        </video>
      </div>
    </div>
  </div>
</section>

<script>
  const videos = document.querySelectorAll<HTMLVideoElement>('[data-autoplay-video]');
  if (videos.length) {
    const tryPlay = async (video: HTMLVideoElement) => {
      if (!video.paused) return;
      video.muted = false;
      try { await video.play(); }
      catch {
        video.muted = true;
        try { await video.play(); } catch { /* user can hit play */ }
      }
    };
    const obs = new IntersectionObserver(
      (entries) => entries.forEach((e) => {
        const v = e.target as HTMLVideoElement;
        if (e.isIntersecting) tryPlay(v); else v.pause();
      }),
      { threshold: 0.35 }
    );
    videos.forEach((v) => obs.observe(v));
  }
</script>
