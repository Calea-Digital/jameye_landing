---
import { Icon } from 'astro-icon/components';
import { t, type Locale } from '~/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const L = t<{
  eyebrow: string;
  title: { lead: string; ital: string };
  sub: string;
  perks: { icon: string; label: string }[];
  cta: { primary: string };
  cols: { rank: string; player: string; points: string; change: string };
  perReferral: string;
  newBadge: string;
  pointsSuffix: string;
  referralsOne: string;
  referralsMany: string;
  search: {
    label: string; placeholder: string; button: string; clear: string;
    rankPrefix: string; jump: string; refLink: string; copied: string; notFound: string;
  };
  pager: { prev: string; next: string; page: string; of: string };
  states: { loading: string; empty: string; error: string };
}>(locale, 'leaderboard');

const CFG = {
  apiBase: 'https://waitlist.jameye.com',
  avatars: {
    avatar_1: '/avatar/01-open-market-trader.svg',
    avatar_2: '/avatar/02-edge-score-explorer.svg',
    avatar_3: '/avatar/03-duel-customizable-fighter.svg',
    avatar_4: '/avatar/04-rapid-duel-fighter.svg',
  },
  pointsPerReferral: 5,
  pageSize: 20,
};
---

<section class="py-12 md:py-16">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8 w-full">
    <!-- Big header banner -->
    <div class="lb-hero">
      <span class="eyebrow">{L.eyebrow}</span>
      <h2 class="lb-hero__title text-white">
        {L.title.lead} <span class="ital-grad">{L.title.ital}</span>
      </h2>
      <p class="lb-hero__sub">{L.sub}</p>

      <div class="lb-perks">
        {L.perks.map((p) => (
          <span class="lb-perk">
            <Icon name={p.icon} class="w-3.5 h-3.5" />
            {p.label}
          </span>
        ))}
      </div>
    </div>

    <div class="lb-card mt-10 md:mt-12">
      <!-- Search -->
      <div class="lb-search">
        <div class="lb-search__field">
          <Icon name="tabler:search" class="lb-search__icon w-4 h-4" />
          <input type="text" class="lb-search__input" data-lb-search placeholder={L.search.placeholder} aria-label={L.search.label} />
          <button type="button" class="lb-search__clear hidden" data-lb-clear aria-label={L.search.clear}>
            <Icon name="tabler:x" class="w-3.5 h-3.5" />
          </button>
        </div>
        <button type="button" class="btn-cta lb-search__btn" data-lb-search-btn>{L.search.button}</button>
      </div>
      <div class="lb-search-result hidden" data-lb-result aria-live="polite"></div>

      <!-- Table -->
      <div class="lb-row lb-head">
        <span class="lb-rank">{L.cols.rank}</span>
        <span>{L.cols.player}</span>
        <span class="lb-points">{L.cols.points}</span>
        <span class="lb-change">{L.cols.change}</span>
      </div>
      <div data-lb-body>
        <p class="lb-state">{L.states.loading}</p>
      </div>

      <!-- Pager -->
      <div class="lb-pager hidden" data-lb-pager></div>
    </div>
  </div>
</section>

<style is:global>
  /* ---- Header banner ---- */
  .lb-hero { text-align: center; max-width: 46rem; margin: 0 auto; }
  .lb-hero__title {
    font-family: var(--font-sans); font-weight: 300;
    font-size: clamp(2.25rem, 5.6vw, 4rem); line-height: 1.04; letter-spacing: -0.035em;
    margin: 1.1rem 0 1.1rem;
  }
  .lb-hero__sub { font-size: 1.05rem; line-height: 1.55; color: var(--ink-muted); max-width: 36rem; margin: 0 auto; }
  .lb-perks { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-top: 1.5rem; }
  .lb-perk {
    display: inline-flex; align-items: center; gap: 0.45rem;
    padding: 0.4rem 0.85rem; border-radius: 9999px;
    font-family: var(--font-mono); font-size: 0.66rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.8); background: rgba(255, 255, 255, 0.04); border: 1px solid var(--hairline-strong);
  }
  .lb-perk svg { color: var(--prize-gold); }

  .lb-card {
    background: var(--glass-card-bg);
    border: 1px solid var(--hairline);
    border-radius: 18px;
    overflow: hidden;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: var(--shadow-soft-chrome);
  }

  /* ---- Search ---- */
  .lb-search { display: flex; gap: 0.6rem; padding: 1rem 0.9rem; border-bottom: 1px solid var(--hairline); }
  @media (min-width: 640px) { .lb-search { padding: 1.1rem 1.5rem; } }
  .lb-search__field { position: relative; flex: 1 1 auto; min-width: 0; display: flex; align-items: center; }
  .lb-search__icon { position: absolute; left: 0.9rem; color: var(--ink-faint); pointer-events: none; }
  .lb-search__input {
    width: 100%; padding: 0.72rem 2.4rem; color: #fff;
    background: rgba(255, 255, 255, 0.04); border: 1px solid var(--hairline-strong); border-radius: 9999px;
    font-family: var(--font-body); font-size: 0.92rem; transition: border-color 150ms ease, background 150ms ease;
  }
  .lb-search__input::placeholder { color: rgba(255, 255, 255, 0.4); }
  .lb-search__input:focus { outline: none; border-color: var(--brand-purple); background: rgba(255, 255, 255, 0.06); }
  .lb-search__clear {
    position: absolute; right: 0.65rem; display: inline-flex; align-items: center; justify-content: center;
    width: 1.5rem; height: 1.5rem; border-radius: 9999px; color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.06);
  }
  .lb-search__clear:hover { color: #fff; }
  .lb-search__btn { flex: 0 0 auto; padding: 0.72rem 1.4rem; }

  .lb-search-result {
    display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
    padding: 0.9rem 1.5rem; border-bottom: 1px solid var(--hairline);
    background: rgba(16, 185, 129, 0.06);
    font-size: 0.9rem; color: #fff;
  }
  .lb-search-result.notfound { background: rgba(244, 63, 94, 0.07); color: rgba(255, 255, 255, 0.75); }
  .lb-search-result .lbr-rank { font-family: var(--font-mono); font-weight: 700; color: var(--win-emerald); }
  .lb-search-result .lbr-name { font-weight: 600; }
  .lb-search-result .lbr-meta { font-family: var(--font-mono); font-size: 0.78rem; color: var(--ink-muted); }
  .lb-search-result .lbr-actions { margin-left: auto; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .lb-search-result .lbr-jump,
  .lb-search-result .lbr-btn {
    font-family: var(--font-mono); font-size: 0.66rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    border-radius: 9999px; padding: 0.35rem 0.85rem; background: transparent; transition: background 150ms ease, color 150ms ease, border-color 150ms ease;
  }
  .lb-search-result .lbr-jump { color: var(--brand-sky); border: 1px solid rgba(91, 141, 255, 0.4); }
  .lb-search-result .lbr-jump:hover { background: rgba(91, 141, 255, 0.12); }
  .lb-search-result .lbr-btn { color: var(--win-emerald); border: 1px solid rgba(16, 185, 129, 0.45); }
  .lb-search-result .lbr-btn:hover { background: rgba(16, 185, 129, 0.12); }
  .lb-search-result .lbr-btn.is-copied { color: #06281f; background-image: var(--gradient-emerald-teal); border-color: transparent; }

  .lb-row {
    display: grid;
    grid-template-columns: 1.75rem minmax(0, 1fr) auto 3rem;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
  }
  @media (min-width: 640px) {
    .lb-row { padding: 0.85rem 1.75rem; gap: 1rem; grid-template-columns: 3rem 1fr auto 5.5rem; }
  }
  .lb-row + .lb-row { border-top: 1px solid var(--hairline); }
  .lb-head {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.02);
  }
  .lb-rank { font-family: var(--font-mono); font-variant-numeric: tabular-nums; color: rgba(255,255,255,0.55); }
  .lb-points, .lb-change { text-align: right; }

  .lb-entry { position: relative; transition: background 150ms ease; }
  .lb-entry .lb-rank { font-size: 0.95rem; font-weight: 600; color: #fff; }

  /* Top 10 — elite tint + accent. */
  .lb-entry.elite { background: rgba(126, 59, 255, 0.06); }
  .lb-entry.elite::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: var(--gradient-violet-magenta);
  }

  /* Top 3 — medal styling, strongest highlight. */
  .lb-entry.top1, .lb-entry.top2, .lb-entry.top3 { background: rgba(250, 204, 21, 0.05); }
  .lb-entry.top1::before, .lb-entry.top2::before, .lb-entry.top3::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px;
  }
  .lb-entry.top1 { background: rgba(250, 204, 21, 0.1); }
  .lb-entry.top1::before { background: var(--prize-gold); box-shadow: 0 0 16px rgba(250,204,21,0.8); }
  .lb-entry.top2::before { background: #cbd5e1; }
  .lb-entry.top3::before { background: var(--heat-orange); }
  .lb-entry.top1 .lb-rank { color: var(--prize-gold); }
  .lb-entry.top2 .lb-rank { color: #cbd5e1; }
  .lb-entry.top3 .lb-rank { color: var(--heat-orange); }
  .lb-medal { font-size: 1rem; line-height: 1; }

  /* The searching user's own row. */
  .lb-entry.is-you {
    background: rgba(16, 185, 129, 0.12);
    box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.4);
  }
  .lb-entry.is-you::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 4px; background: var(--win-emerald); }

  .lb-player { display: flex; align-items: center; gap: 0.6rem; min-width: 0; }
  @media (min-width: 640px) { .lb-player { gap: 0.75rem; } }
  .lb-avatar {
    width: 30px; height: 30px; flex: none;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--hairline);
    object-fit: contain;
    padding: 2px;
  }
  @media (min-width: 640px) { .lb-avatar { width: 38px; height: 38px; } }
  .lb-name {
    font-weight: 500; color: #fff; letter-spacing: -0.01em;
    min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .lb-sub {
    font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.06em;
    color: rgba(255,255,255,0.4); margin-top: 0.15rem;
  }
  .lb-pts {
    font-family: var(--font-mono); font-variant-numeric: tabular-nums;
    font-weight: 600; font-size: 0.9rem; color: #fff;
  }
  @media (min-width: 640px) { .lb-pts { font-size: 1.05rem; } }
  .lb-pts span { font-size: 0.62rem; color: rgba(255,255,255,0.4); margin-left: 0.2rem; }
  @media (min-width: 640px) { .lb-pts span { font-size: 0.7rem; } }

  .lb-delta {
    font-family: var(--font-mono); font-variant-numeric: tabular-nums;
    font-size: 0.8rem; font-weight: 600;
    display: inline-flex; align-items: center; gap: 0.2rem; justify-content: flex-end;
  }
  .lb-delta.up { color: var(--win-emerald); }
  .lb-delta.down { color: var(--alert-rose); }
  .lb-delta.flat { color: rgba(255,255,255,0.3); }
  .lb-delta.new {
    font-size: 0.58rem; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--brand-sky); border: 1px solid rgba(91,141,255,0.4);
    border-radius: 9999px; padding: 0.15rem 0.45rem;
  }

  .lb-state { padding: 2.5rem 1.75rem; text-align: center; color: rgba(255,255,255,0.5); font-size: 0.95rem; }

  /* ---- Pager ---- */
  .lb-pager {
    display: flex; align-items: center; justify-content: center; gap: 0.35rem; flex-wrap: wrap;
    padding: 1rem 1.5rem; border-top: 1px solid var(--hairline); background: rgba(255, 255, 255, 0.02);
  }
  .lb-pg {
    min-width: 2.1rem; height: 2.1rem; padding: 0 0.6rem;
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 0.78rem; font-weight: 600;
    color: rgba(255, 255, 255, 0.7); background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--hairline); border-radius: 0.6rem;
    transition: color 150ms ease, background 150ms ease, border-color 150ms ease;
  }
  .lb-pg:hover:not(:disabled) { color: #fff; background: rgba(255, 255, 255, 0.08); }
  .lb-pg:disabled { opacity: 0.35; cursor: default; }
  .lb-pg.is-current {
    color: #fff; background-image: var(--gradient-brand-sweep);
    border-color: transparent; box-shadow: var(--shadow-brand-halo);
  }
  .lb-pg-ellipsis { color: var(--ink-faint); padding: 0 0.2rem; font-family: var(--font-mono); }
</style>

<script define:vars={{ CFG, L, LOCALE: locale }}>
  const body = document.querySelector('[data-lb-body]');
  const pagerEl = document.querySelector('[data-lb-pager]');
  const searchInput = document.querySelector('[data-lb-search]');
  const searchBtn = document.querySelector('[data-lb-search-btn]');
  const clearBtn = document.querySelector('[data-lb-clear]');
  const resultEl = document.querySelector('[data-lb-result]');

  if (body) {
    const PAGE = CFG.pageSize;
    let LIST = [];
    let page = 0;
    let highlightKey = null;

    const esc = (s) =>
      String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const parseTs = (s) => { const d = new Date(s); return isNaN(d.getTime()) ? 0 : d.getTime(); };
    const refLabel = (n) => (n === 1 ? L.referralsOne : L.referralsMany);
    const referralLink = (nick) => `${location.origin}${LOCALE === 'es' ? '/es/' : '/'}?ref=${encodeURIComponent(nick)}`;

    const deltaHtml = (ch) => {
      if (ch.type === 'new') return `<span class="lb-delta new">${esc(L.newBadge)}</span>`;
      if (ch.type === 'up') return `<span class="lb-delta up">▲ ${ch.n}</span>`;
      if (ch.type === 'down') return `<span class="lb-delta down">▼ ${ch.n}</span>`;
      return `<span class="lb-delta flat">–</span>`;
    };

    const rankClass = (pos) => {
      if (pos <= 3) return ` top${pos}`;
      if (pos <= 10) return ' elite';
      return '';
    };
    const medal = (pos) => (pos === 1 ? '🥇' : pos === 2 ? '🥈' : pos === 3 ? '🥉' : '');

    const rowHtml = (u) => {
      const isYou = highlightKey && u.k === highlightKey ? ' is-you' : '';
      const avatarSrc = CFG.avatars[u.avatar] || CFG.avatars.avatar_1;
      const m = medal(u.posNow);
      return `<div class="lb-row lb-entry${rankClass(u.posNow)}${isYou}" data-key="${esc(u.k)}">
        <span class="lb-rank">${m ? `<span class="lb-medal">${m}</span>` : u.posNow}</span>
        <span class="lb-player">
          <img class="lb-avatar" src="${avatarSrc}" alt="" loading="lazy" />
          <span style="min-width:0;">
            <span class="lb-name">${esc(u.nick)}</span>
            <span class="lb-sub">${u.referrals} ${esc(refLabel(u.referrals))}</span>
          </span>
        </span>
        <span class="lb-points"><span class="lb-pts">${u.pointsNow.toLocaleString()}<span>${esc(L.pointsSuffix)}</span></span></span>
        <span class="lb-change">${deltaHtml(u.change)}</span>
      </div>`;
    };

    const pageCount = () => Math.max(1, Math.ceil(LIST.length / PAGE));

    const renderPager = () => {
      const total = pageCount();
      if (total <= 1) { pagerEl.classList.add('hidden'); pagerEl.innerHTML = ''; return; }
      pagerEl.classList.remove('hidden');

      // Windowed page numbers: 1 … (cur-1 cur cur+1) … total
      const wanted = [];
      for (let p = 1; p <= total; p++) {
        if (p === 1 || p === total || Math.abs(p - (page + 1)) <= 1) wanted.push(p);
      }
      let html = `<button class="lb-pg" data-goto="${page - 1}" ${page === 0 ? 'disabled' : ''}>${esc(L.pager.prev)}</button>`;
      let last = 0;
      for (const p of wanted) {
        if (p - last > 1) html += `<span class="lb-pg-ellipsis">…</span>`;
        html += `<button class="lb-pg${p - 1 === page ? ' is-current' : ''}" data-goto="${p - 1}">${p}</button>`;
        last = p;
      }
      html += `<button class="lb-pg" data-goto="${page + 1}" ${page >= total - 1 ? 'disabled' : ''}>${esc(L.pager.next)}</button>`;
      pagerEl.innerHTML = html;

      pagerEl.querySelectorAll('[data-goto]').forEach((b) => {
        b.addEventListener('click', () => {
          const to = Number(b.getAttribute('data-goto'));
          if (to >= 0 && to < total && to !== page) { page = to; renderPage(); }
        });
      });
    };

    const renderPage = (scrollToHighlight = false) => {
      const start = page * PAGE;
      const slice = LIST.slice(start, start + PAGE);
      body.innerHTML = slice.map(rowHtml).join('');
      renderPager();
      if (scrollToHighlight && highlightKey) {
        const el = Array.from(body.children).find((c) => c.dataset && c.dataset.key === highlightKey);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    };

    const build = (entries) => {
      const cutoff = Date.now() - 7 * 24 * 3600 * 1000;
      const refs = new Map();
      const bump = (k, ts) => { const o = refs.get(k) || { all: 0, old: 0 }; o.all++; if (ts && ts <= cutoff) o.old++; refs.set(k, o); };
      const byNick = new Map();
      for (const row of entries) {
        const nick = (row?.nickname || '').trim();
        const ref = (row?.referred || '').trim().toLowerCase();
        const ts = parseTs(row?.timestamp);
        const avatar = (row?.avatar || '').trim();
        if (nick) {
          const k = nick.toLowerCase();
          const prev = byNick.get(k);
          if (!prev || (ts && (!prev.ts || ts < prev.ts))) byNick.set(k, { nick, ts, avatar });
        }
        if (ref) bump(ref, ts);
      }
      const PTS = CFG.pointsPerReferral;
      const list = [...byNick.entries()].map(([k, u]) => {
        const rc = refs.get(k) || { all: 0, old: 0 };
        return {
          nick: u.nick, k, ts: u.ts, avatar: u.avatar,
          referrals: rc.all, pointsNow: rc.all * PTS, pointsOld: rc.old * PTS,
          existedOld: !!u.ts && u.ts <= cutoff,
        };
      });
      const cmp = (key) => (a, b) => b[key] - a[key] || (a.ts || Infinity) - (b.ts || Infinity) || a.k.localeCompare(b.k);
      const now = [...list].sort(cmp('pointsNow'));
      now.forEach((u, i) => (u.posNow = i + 1));
      const oldPos = new Map();
      [...list].filter((u) => u.existedOld).sort(cmp('pointsOld')).forEach((u, i) => oldPos.set(u.k, i + 1));
      now.forEach((u) => {
        if (!u.existedOld) { u.change = { type: 'new' }; return; }
        const op = oldPos.get(u.k);
        const delta = (op ?? u.posNow) - u.posNow;
        u.change = { type: delta > 0 ? 'up' : delta < 0 ? 'down' : 'flat', n: Math.abs(delta) };
      });
      return now;
    };

    // ---- Search ----
    const runSearch = () => {
      const q = (searchInput?.value || '').trim().toLowerCase();
      clearBtn?.classList.toggle('hidden', !q);
      if (!q) { resultEl.classList.add('hidden'); resultEl.innerHTML = ''; highlightKey = null; renderPage(); return; }
      let u = LIST.find((x) => x.k === q) || LIST.find((x) => x.k.includes(q));
      if (!u) {
        resultEl.className = 'lb-search-result notfound';
        resultEl.innerHTML = esc(L.search.notFound);
        highlightKey = null;
        renderPage();
        return;
      }
      highlightKey = u.k;
      page = Math.floor((u.posNow - 1) / PAGE);
      resultEl.className = 'lb-search-result';
      resultEl.innerHTML =
        `<span class="lbr-rank">${esc(L.search.rankPrefix)}${u.posNow}</span>` +
        `<span class="lbr-name">${esc(u.nick)}</span>` +
        `<span class="lbr-meta">${u.pointsNow.toLocaleString()} ${esc(L.pointsSuffix)} · ${u.referrals} ${esc(refLabel(u.referrals))}</span>` +
        `<span class="lbr-actions">` +
          `<button type="button" class="lbr-btn" data-lb-reflink>${esc(L.search.refLink)}</button>` +
          `<button type="button" class="lbr-jump" data-lb-jump>${esc(L.search.jump)}</button>` +
        `</span>`;
      resultEl.querySelector('[data-lb-jump]')?.addEventListener('click', () => renderPage(true));
      const linkBtn = resultEl.querySelector('[data-lb-reflink]');
      linkBtn?.addEventListener('click', async () => {
        const link = referralLink(u.nick);
        try { await navigator.clipboard.writeText(link); } catch { /* clipboard unavailable */ }
        linkBtn.textContent = L.search.copied;
        linkBtn.classList.add('is-copied');
        setTimeout(() => { linkBtn.textContent = L.search.refLink; linkBtn.classList.remove('is-copied'); }, 1800);
      });
      renderPage(true);
    };

    searchBtn?.addEventListener('click', runSearch);
    searchInput?.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault(); runSearch(); } });
    searchInput?.addEventListener('input', () => clearBtn?.classList.toggle('hidden', !searchInput.value.trim()));
    clearBtn?.addEventListener('click', () => { searchInput.value = ''; runSearch(); searchInput.focus(); });

    // ---- Load ----
    const load = async () => {
      if (!CFG.apiBase) { body.innerHTML = `<p class="lb-state">${esc(L.states.error)}</p>`; return; }
      let entries;
      try {
        const res = await fetch(`${CFG.apiBase}/api/waitlist/entries`, { cache: 'no-store' });
        if (!res.ok) throw new Error(`http_${res.status}`);
        entries = await res.json();
      } catch {
        body.innerHTML = `<p class="lb-state">${esc(L.states.error)}</p>`;
        return;
      }
      if (!Array.isArray(entries) || entries.length === 0) {
        body.innerHTML = `<p class="lb-state">${esc(L.states.empty)}</p>`;
        pagerEl.classList.add('hidden');
        return;
      }
      LIST = build(entries);
      if (page >= pageCount()) page = 0;
      renderPage();
      if (highlightKey) runSearch();
    };

    load();
    window.addEventListener('waitlist:joined', () => setTimeout(load, 1500));
  }
</script>
