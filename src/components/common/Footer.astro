---
import { t, type Locale } from '~/utils/i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const data = t<{
  signature: string;
  legal: { text: string; href: string }[];
}>(locale, 'footer');
---

<footer class="relative z-10 border-t border-white/8 py-8 text-center">
  <div class="max-w-[1280px] mx-auto px-5 md:px-8">
    <div class="meta-label flex flex-wrap items-center justify-center gap-x-3 gap-y-2">
      <span>{data.signature}</span>
      <span class="opacity-40 hidden sm:inline">·</span>
      <span class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
        {
          data.legal.map((link, i) => (
            <>
              <a href={link.href} class="text-white/65 hover:text-white transition-colors normal-case tracking-[0.16em]">
                {link.text}
              </a>
              {i < data.legal.length - 1 ? <span class="opacity-30">·</span> : null}
            </>
          ))
        }
      </span>
    </div>
  </div>
</footer>
