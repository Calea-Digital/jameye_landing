---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/common/Header.astro';
import Footer from '~/components/common/Footer.astro';
import Leaderboard from '~/components/sections/Leaderboard.astro';
import WaitlistModal from '~/components/common/WaitlistModal.astro';
import { t, type Locale } from '~/utils/i18n';

const locale: Locale = 'en';
const meta = t<{ meta: { title: string; description: string } }>(locale, 'leaderboard').meta;
---

<Layout metadata={meta} locale={locale}>
  <Header locale={locale} />
  <main id="top">
    <Leaderboard locale={locale} />
  </main>
  <Footer locale={locale} />
  <WaitlistModal locale={locale} />
</Layout>
