---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/common/Header.astro';
import Footer from '~/components/common/Footer.astro';
import { type Locale } from '~/utils/i18n';

const locale: Locale = 'en';
---

<Layout
  locale={locale}
  metadata={{
    title: '404 — Not Found',
    description: 'Sorry, the page you are looking for does not exist.',
  }}
>
  <Header locale={locale} />
  <section class="min-h-[60vh] flex items-center justify-center px-6">
    <div class="text-center max-w-md">
      <h1 class="text-6xl md:text-7xl font-semibold text-foreground tracking-tight">404</h1>
      <p class="mt-4 text-xl font-medium text-foreground">Page not found</p>
      <p class="mt-3 text-sm text-muted-foreground">Looks like you wandered off the leaderboard.</p>
      <a href="/" class="btn-cta mt-8">Back to home</a>
    </div>
  </section>
  <Footer locale={locale} />
</Layout>
