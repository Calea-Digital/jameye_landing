---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/common/Header.astro';
import Footer from '~/components/common/Footer.astro';
import Hero from '~/components/sections/Hero.astro';
import Bento from '~/components/sections/Bento.astro';
import Roster from '~/components/sections/Roster.astro';
import VideoShowcase from '~/components/sections/VideoShowcase.astro';
import HowItWorks from '~/components/sections/HowItWorks.astro';
import Tournaments from '~/components/sections/Tournaments.astro';
import Progression from '~/components/sections/Progression.astro';
import CtaFinal from '~/components/sections/CtaFinal.astro';
import WaitlistModal from '~/components/common/WaitlistModal.astro';
import { t, type Locale } from '~/utils/i18n';

const locale: Locale = 'en';
const meta = t<{ title: string; description: string }>(locale, 'meta');
---

<Layout metadata={meta} locale={locale}>
  <Header locale={locale} />
  <main id="top">
    <Hero locale={locale} />
    <VideoShowcase locale={locale} />
    <Roster locale={locale} />
    <HowItWorks locale={locale} />
    <Progression locale={locale} />
    <Tournaments locale={locale} />
    <Bento locale={locale} />
    <CtaFinal locale={locale} />
  </main>
  <Footer locale={locale} />
  <WaitlistModal locale={locale} />
</Layout>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-scroll]').forEach((el) => observer.observe(el));
</script>
