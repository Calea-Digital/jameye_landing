# ─────────────────────────────────────────────────────────────────────────────
# Jameye waitlist → backend API
#
# Copy this file to ".env" (already gitignored) and fill in the value below.
# The var MUST start with PUBLIC_ — Astro/Vite only exposes PUBLIC_* to the
# browser, and the waitlist modal / leaderboard / hero counter all run
# client-side.
#
# The modal collects: Name (required), Email (required),
# Nickname (optional — auto-generated server-side if blank),
# Referred by (optional — someone else's nickname), Avatar (one of
# avatar_1 … avatar_4).
#
# Uniqueness for both email and nickname is enforced by the backend
# (POST /api/waitlist/signup returns 409 with detail "email_taken" or
# "nickname_taken"). Live validation uses GET /api/waitlist/check.
# The leaderboard pulls GET /api/waitlist/entries and the hero counter
# pulls GET /api/waitlist/count.
#
# Make sure WAITLIST_CORS_ORIGINS on the backend includes the origin this
# site is served from, otherwise the browser will block every request.
# ─────────────────────────────────────────────────────────────────────────────


# Base URL of the FastAPI waitlist backend (no trailing slash).
# Dev default points at a local uvicorn.
PUBLIC_WAITLIST_API_BASE=http://localhost:8000
# PUBLIC_WAITLIST_API_BASE=https://api.jameye.com   # prod
